---
interface Props {
  class?: string;
  href?: string;
  style?: string;
}

const { class: className, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag href={href} class:list={['card', className]} {...href ? { target: href.startsWith('http') ? '_blank' : undefined, rel: href.startsWith('http') ? 'noopener noreferrer' : undefined } : {}}>
  <slot />
</Tag>

<style>
  .card {
    border: 1px solid var(--color-border);
    padding: 1.25rem;
    background-color: var(--color-surface);
    transition: border-color 0.2s ease;
    text-decoration: none;
    color: inherit;
    display: block;
    cursor: pointer;
  }

  .card:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }
</style>
