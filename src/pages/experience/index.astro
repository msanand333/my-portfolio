---
import { render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/ui/Section.astro";
import Badge from "../../components/ui/Badge.astro";
import { getPublishedExperience } from "../../utils/content";

const experience = await getPublishedExperience();
---

<Layout
  title="Experience | shanmuganand.m"
  description="My complete work history and professional experience as a software engineer."
>
  <main class="main-content page-transition">
    <div class="nav-links inline-nav">
      <a href="/" class="cmd-link">[ ← cd ~ ]</a>
    </div>

    <Section id="experience-full" title="experience" flag="all">
      <div class="timeline">
        <div class="timeline-line"></div>
        {
          experience.map(async (entry, index) => {
            const { Content } = await render(entry);
            return (
              <div
                class="timeline-item reveal"
                style={`transition-delay: ${index * 100}ms`}
              >
                <div class="timeline-dot" />
                <div class="timeline-content">
                  <div class="timeline-header">
                    <h2 class="timeline-role">{entry.data.role}</h2>
                    <span class="timeline-company">@ {entry.data.company}</span>
                  </div>
                  <div class="timeline-meta">
                    <span class="timeline-date">
                      {entry.data.startDate} — {entry.data.endDate}
                    </span>
                    <span class="timeline-location">
                      {" "}
                      | {entry.data.location}
                    </span>
                  </div>

                  <div class="timeline-stack">
                    {entry.data.stack.map((tech: string) => (
                      <Badge label={tech} />
                    ))}
                  </div>

                  <div class="mdx-content">
                    <Content />
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>
    </Section>
  </main>
</Layout>

<style>
  .main-content {
    flex: 1;
    padding-top: 128px;
    padding-bottom: 64px;
  }

  .inline-nav {
    margin-bottom: 32px;
  }

  .cmd-link {
    font-size: 14px;
    color: var(--color-muted);
  }

  .cmd-link:hover {
    color: var(--color-blue);
    text-decoration: none;
  }

  .page-transition {
    animation: fadeIn 0.4s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Timeline (Full variant) */
  .timeline {
    position: relative;
    padding-left: 32px;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .timeline-line {
    position: absolute;
    top: 7px;
    bottom: 0;
    left: 6px;
    width: 2px;
    background-color: var(--color-border);
  }

  .timeline-item {
    position: relative;
  }

  .timeline-dot {
    position: absolute;
    left: -32px;
    top: 6px;
    width: 15px;
    height: 15px;
    background-color: var(--color-bg);
    border: 2px solid var(--color-blue);
    border-radius: 50%;
  }

  .timeline-header {
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 4px;
  }

  .timeline-role {
    font-size: 20px;
    font-weight: 700;
    color: var(--color-accent);
  }

  .timeline-company {
    font-size: 18px;
    color: var(--color-primary);
  }

  .timeline-meta {
    font-size: 14px;
    color: var(--color-muted);
    margin-bottom: 16px;
  }

  .timeline-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }

  /* MDX Content Styles */
  .mdx-content {
    font-size: 15px;
    color: var(--color-primary);
  }

  .mdx-content :global(ul) {
    list-style-type: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .mdx-content :global(li) {
    padding-left: 24px;
    position: relative;
    line-height: 1.6;
  }

  .mdx-content :global(li)::before {
    content: "- ";
    position: absolute;
    left: 0;
    color: var(--color-muted);
  }

  @media (max-width: 768px) {
    .timeline-dot {
      width: 11px;
      height: 11px;
      top: 8px;
    }

    .timeline-line {
      left: 4px;
    }
  }
</style>
